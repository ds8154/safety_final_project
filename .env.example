# ============================================================
# UNICC AI Safety Lab — Environment Configuration Template
# Copy this file to .env and fill in the values below.
# ============================================================

# ------------------------------------------------------------
# Judge 3 — Gemini API (optional)
# If absent, Judge 3 automatically falls back to local Ollama.
# ------------------------------------------------------------
GEMINI_API_KEY=
# GOOGLE_API_KEY=      # Alternative key name accepted by Judge 3
# GEMINI_MODEL=gemini-2.5-flash
# JUDGE3_GEMINI_MODEL=gemini-2.5-flash
# GEMINI_REQUEST_TIMEOUT_SECONDS=120

# ------------------------------------------------------------
# Ollama — local LLM backend (used by Judge 1, Judge 2, and
# Judge 3 fallback when no Gemini key is present)
# ------------------------------------------------------------
OLLAMA_URL=http://localhost:11434/api/generate
DEFAULT_MODEL_NAME=llama3.2:3b
OLLAMA_REQUEST_TIMEOUT_SECONDS=180
OLLAMA_TEMPERATURE=0

# Per-judge model overrides (optional — falls back to DEFAULT_MODEL_NAME)
# JUDGE1_MODEL_NAME=llama3.2:3b
# JUDGE2_MODEL_NAME=llama3.2:3b
# JUDGE3_OLLAMA_MODEL=llama3.2:3b

# ------------------------------------------------------------
# Optional — Mock mode (set to 1 to skip live LLM calls in CI)
# ------------------------------------------------------------
# MOCK_MODE=0
